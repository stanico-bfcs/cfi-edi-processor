      "malformedQuoteCheck": true,
      "fields": [
        {"name": "PatientName", "required": true, "type": "string"},
        {"name": "Sex", "required": false, "type": "string"},
        {"name": "BirthDate", "required": true, "type": "date", "dateFormats": ["%m/%d/%Y", "%-m/%-d/%Y", "%m/%d/%y", "%-m/%-d/%y"]},
        {"name": "RC", "required": false, "type": "string"},
        {"name": "DrugName", "required": true, "type": "string"},
        {"name": "RXNumber", "required": true, "type": "string"},
        {"name": "RXDate", "required": true, "type": "date", "dateFormats": ["%m/%d/%Y", "%-m/%-d/%Y", "%m/%d/%y", "%-m/%-d/%y"]},
