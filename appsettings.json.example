{
  "runtime": {
    "appName": "cfi-edi-processor",
    "environment": "development",
    "logsDirectory": "logs",
    "workingDirectory": "work",
    "liveProviderAllowList": [
      "Kirk_Pharmacy"
    ],
    "failOnFileStatuses": [
      "prefix_failed",
      "staging_failed",
      "preprocessing_failed",
      "duplicate_skipped",
      "duplicate_check_failed",
      "x12_validation_failed",
      "validation_failed",
      "converter_not_configured",
      "conversion_failed",
      "converter_output_verification_failed",
      "x12_received_date_update_failed",
      "x12_received_date_verification_failed",
      "publish_failed",
      "inbox_observation_not_found",
      "inbox_observation_zero_byte"
    ]
  },
  "paths": {
    "sourceRoot": "C:\\EDI\\SFTPRoot",
    "qdsProcessorRoot": "C:\\EDI\\QDS_Processor",
    "x12FilesDirectory": "C:\\EDI\\QDS_Processor\\X12 FILES",
    "converted837IDirectory": "C:\\EDI\\QDS_Processor\\X12 837I CONVERTED TO 837P",
    "incomingDirectory": "C:\\Files\\INCOMING",
    "inboxDirectory": "C:\\Files\\INBOX",
    "converterLogsDirectory": "logs\\converters",
    "validationReportsDirectory": "logs\\validation",
    "templatesDirectory": "templates",
    "renderedNotificationsDirectory": "logs\\notifications"
  },
  "converters": {
    "rxFlatfileTo837P": "C:\\Path\\To\\RXFLATFILE_TO_837P_47.exe",
    "convert837ITo837P": "C:\\Path\\To\\CONVERT_837I_TO_837P.exe",
    "timeoutSeconds": 300
  },
  "publish": {
    "stabilityChecks": 3,
    "stabilityIntervalSeconds": 2,
    "maxRetries": 5,
    "retryDelaySeconds": 5,
    "tempSuffix": ".copying",
    "stagingDirectory": null,
    "observeInbox": false,
    "inboxObservationTimeoutSeconds": 60,
    "inboxObservationIntervalSeconds": 5
  },
  "duplicateCheck": {
    "enabled": false,
    "driver": "ODBC Driver 17 for SQL Server",
    "server": "sql.example.local",
    "database": "TPM_DATABASE_NAME",
    "trustedConnection": true,
    "usernameEnv": "TPM_DB_USERNAME",
    "passwordEnv": "TPM_DB_PASSWORD",
    "table": "batch",
    "fileNameColumn": "file_name",
    "matchMode": "contains",
    "failOnUnavailable": true
  },
  "email": {
    "enabled": false,
    "sendProviderValidationEmails": false,
    "smtpServer": "smtp.example.local",
    "smtpPort": 587,
    "useSsl": true,
    "fromAddress": "no-reply@example.com",
    "defaultRecipients": [
      "edi-notifications@example.com"
    ],
    "usernameEnv": "SMTP_USERNAME",
    "passwordEnv": "SMTP_PASSWORD"
  },
  "transactionReports": {
    "enabled": true,
    "sendEmail": false,
    "recipients": [
      "sftp-inbox@example.com"
    ],
    "subjectPrefix": "EDI transaction count report"
  },
  "receivedDateOverrides": {
    "enabled": true,
    "adminFolderName": "CFI-Admin",
    "fileName": "received_dates.csv",
    "dateFormat": "%Y-%m-%d",
    "cleanup": "delete"
  },
  "x12Validation": {
    "enabled": true,
    "dateOfServiceEnabled": true,
    "serviceDateSegment": "DTP",
    "serviceDateQualifier": "472",
    "rangeFormatQualifier": "RD8",
    "requireServiceDate": true
  },
  "validationSchemas": [
    {
      "key": "kirk_pharmacy_txt",
      "fileType": "csv",
      "delimiter": ",",
      "headerRow": 1,
      "dataStartRow": 2,
      "allowBlankRows": true,
      "strictColumnCount": true,
      "malformedQuoteCheck": true,
      "fields": [
        {"name": "TX-Date Filled", "required": true, "type": "date", "dateFormats": ["%m/%d/%Y"]},
        {"name": "PD-Pat Combined Name", "required": true, "type": "string"},
        {"name": "TX-Quantity Disp", "required": true, "type": "decimal", "min": "0"},
        {"name": "TX-Price", "required": true, "type": "decimal", "min": "0"},
        {"name": "TX-Copay", "required": true, "type": "decimal", "min": "0"},
        {"name": "TX-Primary Amt Due", "required": true, "type": "decimal", "min": "0"},
        {"name": "TX-Price Code", "required": false, "type": "string"},
        {"name": "RX-Drug Name", "required": true, "type": "string"},
        {"name": "DR-Doctor Name(25)", "required": false, "type": "string"},
        {"name": "PD-Patient Birthdate", "required": true, "type": "date", "dateFormats": ["%m/%d/%Y"]},
        {"name": "PI-Ins Group#", "required": true, "type": "member_id", "pattern": "^(\\d{5}-\\d{5}-\\d{2}|\\d{4}-\\d{4}-\\d{2}|-\\s{4}-)$"},
        {"name": "TX-Rx Number", "required": true, "type": "string"},
        {"name": "TX-Remaining Refills", "required": false, "type": "integer", "min": "0"}
      ]
    },
    {
      "key": "care_pharmacy_txt",
      "fileType": "csv",
      "delimiter": ",",
      "headerRow": 1,
      "dataStartRow": 2,
      "allowBlankRows": true,
      "strictColumnCount": true,
      "malformedQuoteCheck": true,
      "fields": [
        {"name": "TX-Date Filled", "required": true, "type": "date", "dateFormats": ["%B %d, %Y"]},
        {"name": "PD-Pat Combined Name", "required": true, "type": "string"},
        {"name": "PI-Ins Policy#", "required": true, "type": "member_id", "pattern": "^(\\d{5}-\\d{5}-\\d{2}|\\d{4}-\\d{4}-\\d{2}|-\\s{4}-).*$"},
        {"name": "DG-Drug Name 27", "required": true, "type": "string"},
        {"name": "TX-Quantity Disp", "required": true, "type": "decimal", "min": "0"},
        {"name": "TX-Price", "required": true, "type": "decimal", "min": "0"},
        {"name": "TX-Copay", "required": true, "type": "decimal", "min": "0"},
        {"name": "TX-Primary Amt Due", "required": true, "type": "decimal", "min": "0"},
        {"name": "TX-Rx Number", "required": true, "type": "string"},
        {"name": "DR-Doctor Name(25)", "required": false, "type": "string"},
        {"name": "PD-Patient Birthdate", "required": true, "type": "date", "dateFormats": ["%B %d, %Y"]},
        {"name": "PC-Description", "required": false, "type": "string"}
      ]
    },
    {
      "key": "valu_med_pharmacy_csv",
      "fileType": "csv",
      "delimiter": ",",
      "headerRow": 1,
      "dataStartRow": 3,
      "allowBlankRows": true,
      "strictColumnCount": true,
      "malformedQuoteCheck": true,
      "fields": [
        {"name": "Last Name", "required": true, "type": "string"},
        {"name": "First Name", "required": true, "type": "string"},
        {"name": "DOB", "required": true, "type": "date", "dateFormats": ["%-d-%b-%y", "%d-%b-%y", "%-d-Sept-%y", "%d-Sept-%y"]},
        {"name": "Group No", "required": true, "type": "member_id", "pattern": "^(\\d{5}-\\d{5}-\\d{2}|\\d{4}-\\d{4}-\\d{2}|-\\s{4}-)$"},
        {"name": "Cert No", "required": false, "type": "string"},
        {"name": "Doctor", "required": false, "type": "string"},
        {"name": "Date", "required": true, "type": "date", "dateFormats": ["%-d-%b-%y", "%d-%b-%y", "%-d-Sept-%y", "%d-Sept-%y"]},
        {"name": "Pres #", "required": true, "type": "string"},
        {"name": "New/Old", "required": false, "type": "string"},
        {"name": "Qty", "required": true, "type": "decimal", "min": "0"},
        {"name": "Medication", "required": true, "type": "string"},
        {"name": "Price-CI", "required": true, "type": "decimal", "min": "0"},
        {"name": "CoPay-CI", "required": true, "type": "decimal", "min": "0"},
        {"name": "Claim-CI", "required": true, "type": "decimal", "min": "0"},
        {"name": "Price-US", "required": false, "type": "decimal", "min": "0"},
        {"name": "CoPay-US", "required": false, "type": "decimal", "min": "0"},
        {"name": "Claim-US", "required": false, "type": "decimal", "min": "0"}
      ]
    },
    {
      "key": "health_care_pharmacy_csv",
      "fileType": "csv",
      "delimiter": ",",
      "headerRow": 1,
      "dataStartRow": 2,
      "allowBlankRows": true,
