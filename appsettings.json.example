        {"name": "TOTAL BILLED", "required": true, "type": "decimal", "min": "0"},
        {"name": "CO-PAY", "required": true, "type": "decimal", "min": "0"},
        {"name": "BALANCE DUE", "required": true, "type": "decimal", "min": "0"},
        {"name": "DATE OF SERVICE (MM/DD/YYYY)", "required": true, "type": "date", "dateFormats": ["%m/%d/%Y", "%-m/%-d/%Y", "excel_serial"]}
      ]
    },
