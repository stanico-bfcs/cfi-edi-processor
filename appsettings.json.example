        {"name": "PolicyNumber", "required": true, "type": "member_id", "pattern": "^(\\d{5}-\\d{5}-\\d{2}|\\d{4}-\\d{4}-\\d{2}|-\\s{4}-)$"},
        {"name": "NDCNumber", "required": false, "type": "string"},
